# Copy to .env and adjust as needed. docker-compose reads this automatically.

# --- Database ---
POSTGRES_USER=tvds_user
POSTGRES_PASSWORD=tvds_password
POSTGRES_DB=tvds_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- App ---
DEBUG=false
ENVIRONMENT=production

# --- ML / Inference ---
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.35

# Custom plate detector (e.g. trained on Mongolian plates). Leave empty to
# disable; the system then OCRs the whole vehicle crop.
# Example: PLATE_MODEL_PATH=/app/models/mn_plate_yolov8.pt
PLATE_MODEL_PATH=
PLATE_CONFIDENCE_THRESHOLD=0.30

# OCR languages. Mongolian plates are Cyrillic -> use "mn,en".
OCR_LANGUAGES=en
# Optional character allow-list to constrain OCR output (Latin+Cyrillic+digits).
# Example: OCR_ALLOWLIST=ABCEHKMOPTYABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789–ź–Ď–í–ď–Ē–ē–Ā–Ė–ó–ė–ô–ö–õ–ú–Ě–ě–ü–†–°–Ę–£–§–•–¶–ß–®–©–™–ę–¨–≠–ģ–Į
OCR_ALLOWLIST=

USE_GPU=false

# --- Rule engine ---
SPEED_TOLERANCE_KMH=0
