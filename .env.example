# Copy to .env and adjust as needed. docker-compose reads this automatically.

# --- Database ---
POSTGRES_USER=tvds_user
POSTGRES_PASSWORD=tvds_password
POSTGRES_DB=tvds_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- App ---
DEBUG=false
ENVIRONMENT=production

# --- ML / Inference ---
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.35

# Custom plate detector (e.g. trained on Mongolian plates). Leave empty to
# disable; the system then OCRs the whole vehicle crop.
# Example: PLATE_MODEL_PATH=/app/models/mn_plate_yolov8.pt
PLATE_MODEL_PATH=
PLATE_CONFIDENCE_THRESHOLD=0.30

# Custom character-level OCR model (ed-bw6q4/mongolia-plates). When present it
# replaces EasyOCR for Mongolian plates. Auto-detected at
# <MODELS_DIR>/mn_plate_ocr_yolo.pt; set PLATE_OCR_MODEL_PATH to override.
MODELS_DIR=/app/models
PLATE_OCR_MODEL_PATH=
PLATE_OCR_CONFIDENCE_THRESHOLD=0.25
PLATE_OCR_IMGSZ=640

# OCR languages. Mongolian plates are Cyrillic -> use "mn,en".
OCR_LANGUAGES=en
# Optional character allow-list to constrain OCR output (Latin+Cyrillic+digits).
# Example: OCR_ALLOWLIST=ABCEHKMOPTYABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789АБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯ
OCR_ALLOWLIST=

USE_GPU=false

# --- Rule engine ---
SPEED_TOLERANCE_KMH=0
